      <column caption='Clean_Units_Sold' datatype='integer' name='[Calculation_0746308257955840]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(REPLACE(REPLACE([Units Sold ], &quot;$&quot;, &quot;&quot;), &quot;,&quot;, &quot;&quot;))' />
