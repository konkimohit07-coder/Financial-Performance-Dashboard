      </column>
      <column caption='Clean_Discounts' datatype='real' name='[Calculation_0746308258516996]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='FLOAT(REPLACE(REPLACE(REPLACE([Discounts ], &quot;$&quot;, &quot;&quot;), &quot;,&quot;, &quot;&quot;), &quot;-&quot;, &quot;0&quot;))' />
      </column>
      <column caption='Clean_Sales' datatype='real' name='[Calculation_0746308258611205]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='FLOAT(REPLACE(REPLACE([Sales ], &quot;$&quot;, &quot;&quot;), &quot;,&quot;, &quot;&quot;))' />
      </column>
      <column caption='Clean_COGS' datatype='real' name='[Calculation_0746308258705414]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='FLOAT(REPLACE(REPLACE([COGS ], &quot;$&quot;, &quot;&quot;), &quot;,&quot;, &quot;&quot;))' />
      </column>
      <column caption='Clean_Profit' datatype='real' name='[Calculation_0746308258811911]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='FLOAT(REPLACE(REPLACE([Profit ], &quot;$&quot;, &quot;&quot;), &quot;,&quot;, &quot;&quot;))' />
      </column>
      <column caption='Profit Margin' datatype='real' name='[Calculation_0746308260274184]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0746308258811911] / [Calculation_0746308258611205] * 100' />
      </column>
      <column caption='Total Discounts' datatype='real' name='[Calculation_0746308260540425]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0746308258516996])' />
      </column>
      <column caption='Total Revenue' datatype='real' name='[Calculation_0746308260622346]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0746308258410499])' />
      </column>
      <column caption='COGS to Sales Ratio' datatype='real' name='[Calculation_0746308260720651]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0746308258705414]) / SUM([Calculation_0746308258611205]) * 100' />
      </column>
      <column caption='Net Sales' datatype='real' name='[Calculation_0746308260847628]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0746308258410499] - [Calculation_0746308258516996]' />
      </column>
      <column caption='Total Cost' datatype='real' name='[Calculation_0746308260954125]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0746308258705414])' />
      </column>
      <column caption=' Discount Percentage' datatype='real' name='[Calculation_0746308261027854]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='([Calculation_0746308258516996] / [Calculation_0746308258410499]) * 100' />
      </column>
      <column caption='Year-over-Year Growth' datatype='real' name='[Calculation_0746308261093391]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(SUM([Calculation_0746308258611205]) - LOOKUP(SUM([Calculation_0746308258611205]), -1)) / ABS(LOOKUP(SUM([Calculation_0746308258611205]), -1)) * 100'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Cumulative Sales' datatype='real' name='[Calculation_0746308261797904]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_SUM(SUM([Calculation_0746308258611205]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Revenue per Unit' datatype='real' name='[Calculation_0746308261933073]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0746308258611205]) / SUM([Calculation_0746308257955840])' />
      </column>
